{
  "kind": "collectionType",
  "collectionName": "app_users",
  "info": {
    "singularName": "app-user",
    "pluralName": "app-users",
    "displayName": "User",
    "description": "Application users that own contacts"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "phoneVerified": {
      "type": "boolean",
      "default": false
    },
    "tenant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tenant.tenant"
    },
    "full_name": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "birthday": {
      "type": "date"
    },
    "occupation": {
      "type": "string"
    },
    "paynow_id_type": {
      "type": "string"
    },
    "paynow_id_value": {
      "type": "string"
    },
    "paynow_name": {
      "type": "string"
    },
    "image_url": {
      "type": "text"
    },
    "tenant_admin_id": {
      "type": "integer"
    },
    "tenant_admin_email": {
      "type": "email"
    },
    "launch_qr_token": {
      "type": "string"
    },
    "device_id": {
      "type": "string",
      "required": true
    }
  }
}
