{
  "kind": "collectionType",
  "collectionName": "app_users",
  "info": {
    "singularName": "app-user",
    "pluralName": "app-users",
    "displayName": "User",
    "description": "Application users that own contacts"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "phone": {
      "type": "string"
    },
    "phoneVerified": {
      "type": "boolean",
      "default": false
    },
    "full_name": {
      "type": "string"
    },
    "ic_number": {
      "type": "string"
    },
    "national_id_number": {
      "type": "string"
    },
    "paynow_id_type": {
      "type": "string"
    },
    "paynow_id_value": {
      "type": "string"
    },
    "paynow_name": {
      "type": "string"
    },
    "paynow_number": {
      "type": "string"
    },
    "paynow_nickname": {
      "type": "string"
    },
    "image_url": {
      "type": "text"
    },
    "device_id": {
      "type": "string",
      "required": true
    }
  }
}
